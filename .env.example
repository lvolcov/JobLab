# joblab — environment configuration template
# Purpose: copy to .env and fill in. Never commit .env.
# Created: 2026-05-19

# --- Postgres ---
POSTGRES_USER=joblab
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=joblab
POSTGRES_PORT=5432

# DATABASE_URL is consumed by the api service. Hostname "db" matches the compose service name.
DATABASE_URL=postgresql+psycopg://joblab:change_me_strong@db:5432/joblab

# --- API ---
API_PORT=8000
# Generate with: python scripts/gen_fernet_key.py
FERNET_KEY=
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
CORS_ORIGINS=http://localhost:5173

# --- Seed admin (used by scripts/seed_admin.py on first boot) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_on_first_login

# --- Uploads ---
MAX_UPLOAD_MB=5

# --- Optional global LLM API keys (admins can add via UI instead) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Web ---
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:8000

# --- E2E ---
# Set to 1 to make the LLM stack return a canned response without hitting any
# provider. Required for Playwright runs and CI.
JOBLAB_TEST_MODE=0
